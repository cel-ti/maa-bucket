// Configure PSScriptAnalyzer settings
{
    "[powershell]": {
        "editor.formatOnSave": true
    },
    "powershell.scriptAnalysis.settingsPath": "PSScriptAnalyzerSettings.psd1",
    "powershell.codeFormatting.preset": "OTBS",
    "powershell.codeFormatting.alignPropertyValuePairs": true,
    "powershell.codeFormatting.ignoreOneLineBlock": true,
    "json.schemas": [
        {
            "fileMatch": ["**/*.meta.json"],
            "schema": {
                "type": "object",
                "properties": {
                    "hasmaapicli": { "type": ["boolean", "null"] },
                    "guiexe": { "type": "string" },
                    "strippingIdentifiers": { "type": "array", "items": { "type": "string" } },
                    "autostartIdentifier": { "type": "string" },
                    "postCompleteIdentifier": { "type": "string" }
                },
                "additionalProperties": true
            }
        },
        {
            "url": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
            "fileMatch": [
                "bucket/**/*.json",
                "!bucket/**/*.meta.json"
            ]
        }
    ],
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/tmp": true
    }
}
